---
import { DEFAULT_LOCALE, isLocale, useTranslations } from '../i18n';

interface Props {
  size?: 'sm' | 'md';
}
const { size = 'md' } = Astro.props;

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);

type IconName = 'github' | 'x' | 'instagram' | 'youtube';
const links: { href: string; label: string; icon: IconName }[] = [
  { href: 'https://github.com/philo-li', label: 'GitHub', icon: 'github' },
  { href: 'https://x.com/philo2022', label: 'X', icon: 'x' },
  { href: 'https://instagram.com/philo1024', label: t('social.photography'), icon: 'instagram' },
  { href: 'https://instagram.com/philoart2020', label: t('social.art'), icon: 'instagram' },
  { href: 'https://youtube.com/c/PhiloArt', label: 'YouTube', icon: 'youtube' },
];
---

<div class:list={['social-links', `social-links--${size}`]}>
  {links.map(link => (
    <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label} class="social-links__item">
      {link.icon === 'github' && (
        <svg class="social-links__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.87-1.54-3.87-1.54-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.72 1.27 3.39.97.11-.75.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.04 0 0 .97-.31 3.19 1.18a11.1 11.1 0 0 1 5.81 0c2.22-1.49 3.18-1.18 3.18-1.18.63 1.58.23 2.75.12 3.04.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.26 5.68.42.36.79 1.07.79 2.17 0 1.57-.01 2.84-.01 3.22 0 .31.21.67.8.56 4.56-1.52 7.85-5.83 7.85-10.91C23.5 5.65 18.35.5 12 .5z"></path>
        </svg>
      )}
      {link.icon === 'x' && (
        <svg class="social-links__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117l11.966 15.644z"></path>
        </svg>
      )}
      {link.icon === 'instagram' && (
        <svg class="social-links__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
      )}
      {link.icon === 'youtube' && (
        <svg class="social-links__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path>
        </svg>
      )}
    </a>
  ))}
</div>

<style>
  .social-links {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }
  .social-links__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }
  .social-links__item:hover {
    color: var(--color-heading);
  }
  .social-links__icon {
    width: 21px;
    height: 21px;
    display: block;
  }
  .social-links--sm {
    gap: 1rem;
  }
  .social-links--sm .social-links__icon {
    width: 19px;
    height: 19px;
  }
</style>
