---
import { DEFAULT_LOCALE, isLocale, useTranslations } from '../i18n';

interface Props {
  size?: 'sm' | 'md';
}
const { size = 'md' } = Astro.props;

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);

const links: { href: string; label: string; icon?: 'youtube' }[] = [
  { href: 'https://github.com/philo-li', label: 'GitHub' },
  { href: 'https://x.com/philo2022', label: 'X' },
  { href: 'https://instagram.com/philo1024', label: t('social.photography') },
  { href: 'https://instagram.com/philoart2020', label: t('social.art') },
  { href: 'https://youtube.com/c/PhiloArt', label: 'YouTube', icon: 'youtube' },
];
---

<div class:list={['social-links', `social-links--${size}`]}>
  {links.map(link => (
    <a href={link.href} target="_blank" rel="noopener noreferrer" aria-label={link.label} title={link.label} class="social-links__item">
      {link.icon === 'youtube' ? (
        <svg class="social-links__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path>
        </svg>
      ) : link.label}
    </a>
  ))}
</div>

<style>
  .social-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }
  .social-links__item {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  .social-links__item:hover {
    color: var(--color-heading);
  }
  .social-links__icon {
    width: 21px;
    height: 21px;
    display: block;
  }
  .social-links--sm {
    gap: 1rem;
  }
  .social-links--sm .social-links__item {
    font-size: 1.05rem;
  }
</style>
