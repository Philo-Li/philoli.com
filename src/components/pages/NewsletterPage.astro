---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DEFAULT_LOCALE, isLocale, useTranslations } from '../../i18n';
import SubscribeForm from '../forms/SubscribeForm.astro';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);
---

<BaseLayout title={t('metadata.newsletterTitle')} description={t('metadata.newsletterDescription')}>
  <main class="newsletter-page">
    <div
      class="newsletter-page__banner newsletter-page__banner--ok"
      data-banner="confirmed"
      hidden
    >
      {t('subscribeForm.successBanner')}
    </div>
    <div
      class="newsletter-page__banner newsletter-page__banner--ok"
      data-banner="unsubscribed"
      hidden
    >
      {t('subscribeForm.unsubscribedBanner')}
    </div>
    <div
      class="newsletter-page__banner newsletter-page__banner--err"
      data-banner="invalid_token"
      hidden
    >
      {t('subscribeForm.invalidTokenBanner')}
    </div>
    <h1 class="newsletter-page__title">{t('newsletterPage.title')}</h1>
    <div class="newsletter-page__grid">
      <div class="newsletter-card">
        <h2 class="newsletter-card__name">{t('newsletterCta.headline')}</h2>
        <p class="newsletter-card__desc">{t('newsletterCta.desc')}</p>
        <SubscribeForm />
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  let key: string | null = null;
  if (params.get('confirmed') === '1') key = 'confirmed';
  else if (params.get('unsubscribed') === '1') key = 'unsubscribed';
  else if (params.get('error') === 'invalid_token') key = 'invalid_token';
  if (key) {
    const el = document.querySelector(`[data-banner="${key}"]`);
    if (el instanceof HTMLElement) el.hidden = false;
  }
</script>

<style>
  .newsletter-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: calc(var(--nav-height) + var(--space-lg)) var(--space-md) var(--space-xl);
  }
  .newsletter-page__title {
    font-size: 2.5rem;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--color-heading);
    font-weight: 500;
    margin-bottom: var(--space-lg);
  }
  .newsletter-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-md);
  }
  .newsletter-card {
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0;
  }
  .newsletter-card__name {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: var(--space-xs);
  }
  .newsletter-card__lang {
    font-size: 0.75rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: var(--space-sm);
  }
  .newsletter-card__desc {
    font-size: 0.9rem;
    color: var(--color-text-subtle);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }
  .newsletter-card__button {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: 0;
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.2s ease;
  }
  .newsletter-card__button:hover {
    background: var(--color-accent-hover);
  }
  .newsletter-page__banner {
    padding: var(--space-sm) var(--space-md);
    margin-bottom: var(--space-md);
    font-size: 0.9rem;
  }
  .newsletter-page__banner--ok {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-left: 3px solid var(--color-accent);
  }
  .newsletter-page__banner--err {
    background: color-mix(in srgb, #c0392b 10%, transparent);
    border-left: 3px solid #c0392b;
  }
</style>
