---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { DEFAULT_LOCALE, formatDate, isLocale, localizedPath, useTranslations } from '../../i18n';
import SubscribeForm from '../forms/SubscribeForm.astro';
import { getCollection } from 'astro:content';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);

const BRAND_BY_LANG: Record<string, string> = {
  zh: 'Philo 说会儿',
  'zh-TW': 'Philo 說會兒',
};
const brand = BRAND_BY_LANG[locale] ?? "Philo's Reflections";

const FEATURED_SLUGS = [
  'the-world-as-I-see-it',
  '2025-top-rated-reading-list',
  'being-mortal',
  'how-to-be-creative',
  'life-is-a-game',
];

// Astro's glob loader lowercases folder names (zh-TW → zh-tw) and slugs.
const prefix = `${locale.toLowerCase()}/`;
const zhPrefix = 'zh/';

const allPosts = await getCollection('blog');

function pickPost(slug: string) {
  const slugLower = slug.toLowerCase();
  return (
    allPosts.find(p => p.id === `${prefix}${slugLower}`) ??
    allPosts.find(p => p.id === `${zhPrefix}${slugLower}`)
  );
}

const featuredPosts = FEATURED_SLUGS
  .map(slug => ({ slug, post: pickPost(slug) }))
  .filter((x): x is { slug: string; post: NonNullable<ReturnType<typeof pickPost>> } => x.post !== undefined);

const site = String(Astro.site).replace(/\/+$/, '');
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<BaseLayout title={t('metadata.newsletterTitle')} description={t('metadata.newsletterDescription')} structuredData={[{ '@type': 'WebPage' as const, name: t('metadata.newsletterTitle'), url: pageUrl, isPartOf: { '@type': 'WebSite' as const, name: 'Philo Li', url: site } }]}>
  <main class="newsletter-page">
    <div
      class="newsletter-page__banner newsletter-page__banner--err"
      data-banner="invalid_token"
      hidden
    >
      {t('subscribeForm.invalidTokenBanner')}
    </div>
    <div
      class="newsletter-page__banner newsletter-page__banner--ok"
      data-banner="unsubscribed"
      hidden
    >
      {t('subscribeForm.unsubscribedBanner')}
    </div>

    <section class="newsletter-page__default" data-state="default">
      <h1 class="newsletter-page__title">{t('newsletterPage.title')}</h1>
      <div class="newsletter-page__grid">
        <div class="newsletter-card">
          <h2 class="newsletter-card__name">{t('newsletterCta.headline')}</h2>
          <p class="newsletter-card__desc">{t('newsletterCta.desc')}</p>
          <SubscribeForm />
        </div>
      </div>
    </section>

    <section class="welcome" data-state="welcome" hidden>
      <header class="welcome__hero">
        <div class="welcome__brand">{brand}</div>
        <div class="welcome__divider" aria-hidden="true"></div>
        <h2 class="welcome__title">{t('newsletterPage.welcomeTitle')}</h2>
        <p class="welcome__body">{t('newsletterPage.welcomeBody')}</p>
      </header>

      <div class="welcome__section-label">{t('newsletterPage.startHere')}</div>

      <ul class="welcome__posts">
        {featuredPosts.map(({ slug, post }) => {
          const href = localizedPath(`/blog/${slug.toLowerCase()}`, locale);
          const cover = post.data.cover;
          const date = formatDate(post.data.date, locale, { year: 'numeric', month: 'short', day: 'numeric' });
          return (
            <li class="welcome-post">
              <a href={href} class="welcome-post__link">
                <div class:list={['welcome-post__cover', { 'welcome-post__cover--placeholder': !cover }]}>
                  {cover ? (
                    <img src={cover} alt="" loading="lazy" />
                  ) : (
                    <span class="welcome-post__cover-glyph" aria-hidden="true">{post.data.title.charAt(0)}</span>
                  )}
                </div>
                <div class="welcome-post__body">
                  <h3 class="welcome-post__title">{post.data.title}</h3>
                  {post.data.description && (
                    <p class="welcome-post__desc">{post.data.description}</p>
                  )}
                  <div class="welcome-post__meta">
                    <time>{date}</time>
                  </div>
                </div>
              </a>
            </li>
          );
        })}
      </ul>

      <div class="welcome__footer">
        <a href={localizedPath('/blog', locale)} class="welcome__browse">{t('newsletterPage.browseAll')}</a>
        <p class="welcome__reply">{t('newsletterPage.replyInvite')}</p>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const confirmed = params.get('confirmed') === '1';
  const unsubscribed = params.get('unsubscribed') === '1';
  const invalidToken = params.get('error') === 'invalid_token';

  if (confirmed) {
    document.querySelector<HTMLElement>('[data-state="default"]')?.setAttribute('hidden', '');
    document.querySelector<HTMLElement>('[data-state="welcome"]')?.removeAttribute('hidden');
  }
  if (unsubscribed) {
    document.querySelector<HTMLElement>('[data-banner="unsubscribed"]')?.removeAttribute('hidden');
  }
  if (invalidToken) {
    document.querySelector<HTMLElement>('[data-banner="invalid_token"]')?.removeAttribute('hidden');
  }
</script>

<style>
  .newsletter-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: calc(var(--nav-height) + var(--space-lg)) var(--space-md) var(--space-xl);
  }

  /* ---- Default subscribe state ---- */
  .newsletter-page__title {
    font-size: 2.5rem;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--color-heading);
    font-weight: 500;
    margin-bottom: var(--space-lg);
  }
  .newsletter-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-md);
  }
  .newsletter-card {
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .newsletter-card__name {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: var(--space-xs);
  }
  .newsletter-card__desc {
    font-size: 0.9rem;
    color: var(--color-text-subtle);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  /* ---- Banners ---- */
  .newsletter-page__banner {
    padding: var(--space-sm) var(--space-md);
    margin-bottom: var(--space-md);
    font-size: 0.9rem;
  }
  .newsletter-page__banner--ok {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-left: 3px solid var(--color-accent);
  }
  .newsletter-page__banner--err {
    background: color-mix(in srgb, #c0392b 10%, transparent);
    border-left: 3px solid #c0392b;
  }

  /* ---- Welcome state ---- */
  .welcome {
    max-width: 680px;
    margin: 0 auto;
  }
  .welcome__hero {
    text-align: center;
    padding: var(--space-md) 0 var(--space-lg);
  }
  .welcome__brand {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 1.5px;
    color: var(--color-heading);
  }
  .welcome__divider {
    width: 36px;
    height: 2px;
    background: var(--color-accent);
    margin: 18px auto 32px;
  }
  .welcome__title {
    font-size: 2.4rem;
    font-weight: 600;
    color: var(--color-heading);
    margin: 0 0 18px;
    letter-spacing: -0.5px;
  }
  .welcome__body {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-text-subtle);
    max-width: 520px;
    margin: 0 auto;
  }
  .welcome__section-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--color-text-muted);
    text-align: center;
    margin: var(--space-lg) 0 var(--space-md);
  }

  .welcome__posts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .welcome-post {
    border-top: 1px solid var(--color-border);
  }
  .welcome-post:last-child {
    border-bottom: 1px solid var(--color-border);
  }
  .welcome-post__link {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    color: var(--color-text);
    transition: opacity 0.2s ease;
  }
  .welcome-post__link:hover {
    opacity: 0.75;
  }
  .welcome-post__cover {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .welcome-post__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .welcome-post__cover--placeholder {
    background: color-mix(in srgb, var(--color-accent) 14%, var(--color-bg));
    color: var(--color-accent);
  }
  .welcome-post__cover-glyph {
    font-size: 2.4rem;
    font-weight: 600;
    letter-spacing: -1px;
    line-height: 1;
    opacity: 0.85;
  }
  .welcome-post__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .welcome-post__title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-heading);
    margin: 0 0 6px;
    line-height: 1.4;
  }
  .welcome-post__desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-text-subtle);
    margin: 0 0 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .welcome-post__meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.5px;
  }

  .welcome__footer {
    margin-top: var(--space-lg);
    text-align: center;
  }
  .welcome__browse {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }
  .welcome__browse:hover {
    color: var(--color-accent-hover);
  }
  .welcome__reply {
    margin-top: var(--space-md);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 560px) {
    .welcome__title {
      font-size: 1.9rem;
    }
    .welcome-post__link {
      grid-template-columns: 96px 1fr;
      gap: var(--space-sm);
    }
    .welcome-post__cover-glyph {
      font-size: 1.8rem;
    }
    .welcome-post__title {
      font-size: 1rem;
    }
    .welcome-post__desc {
      -webkit-line-clamp: 3;
    }
  }
</style>
