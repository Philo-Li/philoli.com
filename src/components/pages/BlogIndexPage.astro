---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { DEFAULT_LOCALE, isLocale, useTranslations } from '../../i18n';
import '../../styles/blog.css';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);

const allPosts = await getCollection('blog');
const isEnglish = locale === 'en';

const posts = allPosts
  .filter(post => {
    const isEnPost = post.id.endsWith('-en');
    if (isEnglish) {
      // Show English version if available, otherwise show the original
      if (isEnPost) return true;
      const hasEnVersion = allPosts.some(p => p.id === `${post.id}-en`);
      return !hasEnVersion;
    } else {
      // Non-English locale: show only non-en posts
      return !isEnPost;
    }
  })
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={t('metadata.blogTitle')} description={t('metadata.blogDescription')}>
  <main class="blog-page">
    <h1 class="blog-page__title">{t('blogPage.title')}</h1>
    <ul class="blog-page__list">
      {posts.map(post => (
        <li>
          <BlogPostCard
            title={post.data.title}
            date={post.data.date}
            slug={post.id}
            tags={post.data.tags}
          />
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>
