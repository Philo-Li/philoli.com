---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../Hero.astro';
import ArtworkStrip from '../ArtworkStrip.astro';
import RecentPosts from '../RecentPosts.astro';
import NewsletterCTA from '../NewsletterCTA.astro';
import { DEFAULT_LOCALE, isLocale, useTranslations } from '../../i18n';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);
const site = String(Astro.site).replace(/\/+$/, '');

const homeSchema = [
  {
    '@type': 'Organization' as const,
    name: 'Philo Li',
    url: site,
    sameAs: [
      'https://x.com/philo2022',
      'https://github.com/philo2022',
      'https://philoart.io',
    ],
  },
  {
    '@type': 'WebSite' as const,
    name: 'Philo Li',
    url: site,
  },
];
---

<BaseLayout
  title={t('metadata.siteTitle')}
  structuredData={homeSchema}
  lcpImage="/images/optimized/hero1-md.webp"
  lcpImageSrcSet="/images/optimized/hero1-sm.webp 450w, /images/optimized/hero1-md.webp 900w, /images/optimized/hero1-lg.webp 1800w"
  lcpImageSizes="(max-width: 768px) 100vw, 50vw"
>
  <Hero />
  <ArtworkStrip />
  <RecentPosts />
  <NewsletterCTA />
</BaseLayout>

