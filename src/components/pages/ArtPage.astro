---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Gallery from '../Gallery.tsx';
import { fetchAllArtworks, getPhiloArtPhotoUrl, shuffleArtworks } from '../../lib/philoart';
import { DEFAULT_LOCALE, isLocale, useTranslations } from '../../i18n';
import '../../styles/gallery.css';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);
const site = String(Astro.site).replace(/\/+$/, '');
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const artworks = shuffleArtworks(await fetchAllArtworks());

const galleryData = artworks.map(a => ({
  id: a.id,
  title: a.title,
  type: a.type,
  width: a.width,
  height: a.height,
  color: a.color,
  srcSmall: a.srcSmall,
  srcLarge: a.srcLarge,
  year: a.year,
  sourceUrl: getPhiloArtPhotoUrl(a),
}));

const artSchema = [
  {
    '@type': 'CollectionPage' as const,
    name: t('metadata.artTitle'),
    url: pageUrl,
    description: t('metadata.artDescription'),
    isPartOf: { '@type': 'WebSite' as const, name: 'Philo Li', url: site },
  },
];
---

<BaseLayout title={t('metadata.artTitle')} description={t('metadata.artDescription')} structuredData={artSchema}>
  <main class="art-page">
    <h1 class="art-page__title">{t('artPage.title')}</h1>
    <Gallery client:load artworks={galleryData} locale={locale} />
  </main>
</BaseLayout>
