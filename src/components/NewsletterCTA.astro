<section class="newsletter-cta">
  <div class="newsletter-cta__inner">
    <div class="newsletter-cta__text">
      <span class="newsletter-cta__label">Newsletter</span>
      <h2 class="newsletter-cta__headline">
        Stay curious<span class="dot">.</span>
      </h2>
      <p class="newsletter-cta__desc">
        Thoughts on art, life, and building things — delivered to your inbox.
      </p>
    </div>
    <div class="newsletter-cta__actions">
      <a href="https://shuo.philoli.com" target="_blank" rel="noopener noreferrer" class="newsletter-cta__button">
        Philo 说会儿 <span class="newsletter-cta__lang">中文</span>
      </a>
      <a href="https://reflections.philoli.com" target="_blank" rel="noopener noreferrer" class="newsletter-cta__button newsletter-cta__button--outline">
        Reflections <span class="newsletter-cta__lang">EN</span>
      </a>
    </div>
  </div>
</section>

<style>
  .newsletter-cta {
    padding: var(--space-xl) var(--space-lg);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .newsletter-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: 0;
  }

  .newsletter-cta__label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 4px;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .newsletter-cta__headline {
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1;
  }

  .newsletter-cta__headline .dot {
    color: var(--color-accent);
  }

  .newsletter-cta__desc {
    margin-top: var(--space-xs);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    max-width: 400px;
  }

  .newsletter-cta__actions {
    display: flex;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .newsletter-cta__button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.7rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: 0;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition: all 0.2s ease;
  }

  .newsletter-cta__button:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .newsletter-cta__button--outline {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-subtle);
  }

  .newsletter-cta__button--outline:hover {
    background: transparent;
    border-color: var(--color-accent);
    color: var(--color-white);
  }

  .newsletter-cta__lang {
    font-size: 0.6rem;
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .newsletter-cta {
      padding: var(--space-lg) var(--space-md);
    }

    .newsletter-cta__inner {
      flex-direction: column;
      text-align: center;
      padding: var(--space-md);
    }

    .newsletter-cta__desc {
      max-width: none;
    }

    .newsletter-cta__actions {
      flex-direction: column;
      width: 100%;
    }

    .newsletter-cta__button {
      justify-content: center;
    }
  }
</style>
