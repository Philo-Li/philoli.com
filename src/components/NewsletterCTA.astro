<section class="newsletter-cta">
  <div class="newsletter-cta__inner">
    <div class="newsletter-cta__info">
      <h2 class="newsletter-cta__title">Philo 说会儿 · Reflections</h2>
      <p class="newsletter-cta__desc">Subscribe to my newsletter — thoughts on art, life, and building things.</p>
    </div>
    <a href="/newsletter" class="newsletter-cta__button">Subscribe</a>
  </div>
</section>

<style>
  .newsletter-cta {
    padding: var(--space-lg) var(--space-md);
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .newsletter-cta__inner {
    padding: var(--space-md);
    background: rgba(100, 108, 255, 0.06);
    border: 1px solid rgba(100, 108, 255, 0.15);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .newsletter-cta__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-white);
  }
  .newsletter-cta__desc {
    margin-top: var(--space-xs);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .newsletter-cta__button {
    flex-shrink: 0;
    padding: 0.6rem 1.5rem;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.2s ease;
  }
  .newsletter-cta__button:hover {
    background: var(--color-accent-hover);
  }
  @media (max-width: 768px) {
    .newsletter-cta__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
