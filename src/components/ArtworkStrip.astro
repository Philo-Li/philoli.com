---
import { fetchRecentArtworks } from '../lib/philoart';

const artworks = await fetchRecentArtworks(12);
---

<section class="artwork-strip">
  <div class="artwork-strip__scroll">
    {artworks.map(art => (
      <a href="/art" class="artwork-strip__item">
        <img src={art.srcSmall} alt={art.title} loading="lazy" />
      </a>
    ))}
  </div>
</section>

<style>
  .artwork-strip {
    width: 100%;
    overflow: hidden;
    padding: var(--space-xs) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .artwork-strip__scroll {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .artwork-strip__scroll::-webkit-scrollbar {
    display: none;
  }

  .artwork-strip__item {
    flex: 0 0 auto;
    width: 280px;
    height: 200px;
    overflow: hidden;
    position: relative;
  }

  .artwork-strip__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease, filter 0.5s ease;
    filter: brightness(0.8);
  }

  .artwork-strip__item:hover img {
    transform: scale(1.05);
    filter: brightness(1);
  }

  @media (max-width: 768px) {
    .artwork-strip__item {
      width: 200px;
      height: 150px;
    }
  }
</style>
