---
import '../styles/navbar.css';

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/art', label: 'Art' },
  { href: '/projects', label: 'Projects' },
  { href: '/newsletter', label: 'Newsletter' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav class="navbar" id="navbar">
  <a href="/" class="navbar__logo">PHILO LI</a>

  <ul class="navbar__links">
    {navLinks.map(link => (
      <li>
        <a
          href={link.href}
          class:list={['navbar__link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="navbar__actions">
    <button class="navbar__theme-toggle" id="theme-toggle" type="button" aria-label="Switch color theme">
      <span class="navbar__theme-indicator" aria-hidden="true"></span>
      <span class="navbar__theme-label" id="theme-toggle-label">Dark</span>
    </button>

    <button class="navbar__hamburger" id="hamburger" type="button" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <ul class="navbar__mobile-menu" id="mobile-menu">
    {navLinks.map(link => (
      <li><a href={link.href}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const themeToggle = document.getElementById('theme-toggle')!;
  const themeToggleLabel = document.getElementById('theme-toggle-label')!;
  const root = document.documentElement;
  const storageKey = 'theme';

  const syncThemeToggle = () => {
    const theme = root.dataset.theme === 'light' ? 'light' : 'dark';
    themeToggleLabel.textContent = theme === 'light' ? 'Light' : 'Dark';
    themeToggle.setAttribute('aria-label', theme === 'light' ? 'Switch to dark mode' : 'Switch to light mode');
  };

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 100);
  });

  themeToggle.addEventListener('click', () => {
    const nextTheme = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = nextTheme;
    localStorage.setItem(storageKey, nextTheme);
    syncThemeToggle();
  });

  hamburger.addEventListener('click', () => {
    mobileMenu.classList.toggle('open');
  });

  syncThemeToggle();
</script>
