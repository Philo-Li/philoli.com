---
import LanguageSwitcher from './LanguageSwitcher.astro';
import {
  DEFAULT_LOCALE,
  isLocale,
  localizedPath,
  unlocalizedPath,
  useTranslations,
} from '../i18n';
import '../styles/navbar.css';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);

const navLinks = [
  { path: '/blog', label: t('nav.blog') },
  { path: '/art', label: t('nav.art') },
  { path: '/projects', label: t('nav.projects') },
  { path: '/newsletter', label: t('nav.newsletter') },
  { path: '/about', label: t('nav.about') },
];

const currentBasePath = unlocalizedPath(Astro.url.pathname);
---

<nav class="navbar" id="navbar">
  <a href={localizedPath('/', locale)} class="navbar__logo">PHILO LI</a>

  <ul class="navbar__links">
    {navLinks.map(link => (
      <li>
        <a
          href={localizedPath(link.path, locale)}
          class:list={['navbar__link', { active: currentBasePath.startsWith(link.path) }]}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <div class="navbar__actions">
    <LanguageSwitcher />

    <button
      class="navbar__theme-toggle"
      id="theme-toggle"
      type="button"
      aria-label={t('theme.toggleAria')}
      data-label-light={t('theme.light')}
      data-label-dark={t('theme.dark')}
      data-aria-to-light={t('theme.toggleToLight')}
      data-aria-to-dark={t('theme.toggleToDark')}
    >
      <span class="navbar__theme-indicator" aria-hidden="true"></span>
      <span class="navbar__theme-label" id="theme-toggle-label">{t('theme.dark')}</span>
    </button>

    <button class="navbar__hamburger" id="hamburger" type="button" aria-label={t('nav.menuLabel')}>
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <ul class="navbar__mobile-menu" id="mobile-menu">
    {navLinks.map(link => (
      <li><a href={localizedPath(link.path, locale)}>{link.label}</a></li>
    ))}
  </ul>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const themeToggle = document.getElementById('theme-toggle')!;
  const themeToggleLabel = document.getElementById('theme-toggle-label')!;
  const root = document.documentElement;
  const storageKey = 'theme';

  const labelLight = themeToggle.dataset.labelLight ?? 'Light';
  const labelDark = themeToggle.dataset.labelDark ?? 'Dark';
  const ariaToLight = themeToggle.dataset.ariaToLight ?? 'Switch to light mode';
  const ariaToDark = themeToggle.dataset.ariaToDark ?? 'Switch to dark mode';

  const syncThemeToggle = () => {
    const theme = root.dataset.theme === 'light' ? 'light' : 'dark';
    themeToggleLabel.textContent = theme === 'light' ? labelLight : labelDark;
    themeToggle.setAttribute('aria-label', theme === 'light' ? ariaToDark : ariaToLight);
  };

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 100);
  });

  themeToggle.addEventListener('click', () => {
    const nextTheme = root.dataset.theme === 'light' ? 'dark' : 'light';
    root.dataset.theme = nextTheme;
    localStorage.setItem(storageKey, nextTheme);
    syncThemeToggle();
  });

  hamburger.addEventListener('click', () => {
    mobileMenu.classList.toggle('open');
  });

  syncThemeToggle();
</script>
