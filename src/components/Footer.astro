---
import SocialLinks from './SocialLinks.astro';
import { DEFAULT_LOCALE, isLocale } from '../i18n';
import { feedUrlFor } from '../lib/rss';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const rssHref = feedUrlFor(locale);
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <span class="footer__logo">Philo Li</span>
      <p class="footer__copy">&copy; {new Date().getFullYear()}</p>
    </div>
    <div class="footer__right">
      <SocialLinks size="sm" />
      <a href={rssHref} class="footer__rss" aria-label="RSS feed" title="RSS">
        <svg width="21" height="21" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M4 4a16 16 0 0 1 16 16h-3A13 13 0 0 0 4 7V4Zm0 6a10 10 0 0 1 10 10h-3a7 7 0 0 0-7-7v-3Zm2 7a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-md) var(--space-lg);
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__left {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .footer__right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer__logo {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .footer__copy {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .footer__rss {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .footer__rss:hover {
    color: var(--color-heading);
  }

  @media (max-width: 768px) {
    .footer {
      padding: var(--space-md);
    }

    .footer__inner {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
