---
import SocialLinks from './SocialLinks.astro';
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <span class="footer__logo">Philo Li</span>
      <p class="footer__copy">&copy; {new Date().getFullYear()}</p>
    </div>
    <SocialLinks size="sm" />
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-md) var(--space-lg);
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer__left {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .footer__logo {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .footer__copy {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .footer {
      padding: var(--space-md);
    }

    .footer__inner {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
