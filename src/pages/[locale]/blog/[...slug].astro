---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import { NON_DEFAULT_LOCALES } from '../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    const contentLocale = locale.toLowerCase();
    const slugMap = new Map();
    // First pass: take exact-locale matches
    for (const post of posts) {
      const [lang, ...rest] = post.id.split('/');
      const slug = rest.join('/');
      if (lang === contentLocale) {
        slugMap.set(slug, post);
      }
    }
    // Second pass: fall back to zh for slugs not yet covered
    for (const post of posts) {
      const [lang, ...rest] = post.id.split('/');
      const slug = rest.join('/');
      if (lang === 'zh' && !slugMap.has(slug)) {
        slugMap.set(slug, post);
      }
    }

    // Stable sort newest → oldest for prev/next + recommendations.
    const ordered = Array.from(slugMap.entries())
      .sort((a, b) => b[1].data.date.valueOf() - a[1].data.date.valueOf());

    const summarize = (entry: [string, any]) => ({
      slug: entry[0],
      title: entry[1].data.title,
      cover: entry[1].data.cover ?? null,
      date: entry[1].data.date,
    });

    for (let i = 0; i < ordered.length; i++) {
      const [slug, post] = ordered[i];
      const newer = ordered[i - 1];
      const older = ordered[i + 1];
      const moreReading = post.data.hideMoreReading
        ? []
        : ordered.filter((_, idx) => idx !== i).slice(0, 3).map(summarize);
      paths.push({
        params: { locale, slug },
        props: {
          post,
          prev: older ? summarize(older) : null,
          next: newer ? summarize(newer) : null,
          moreReading,
        },
      });
    }
  }
  return paths;
}

const { post, prev, next, moreReading } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPostLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  cover={post.data.cover}
  tags={post.data.tags}
  toc={post.data.toc}
  headings={headings}
  prev={prev}
  next={next}
  moreReading={moreReading}
>
  <Content />
</BlogPostLayout>
