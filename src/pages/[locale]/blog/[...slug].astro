---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../../layouts/BlogPostLayout.astro';
import { NON_DEFAULT_LOCALES } from '../../../i18n';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const paths = [];
  for (const locale of NON_DEFAULT_LOCALES) {
    // Astro's glob loader lowercases folder names via githubSlug, so zh-TW/ → zh-tw/
    const contentLocale = locale.toLowerCase();
    const slugMap = new Map();
    // First pass: take exact-locale matches
    for (const post of posts) {
      const [lang, ...rest] = post.id.split('/');
      const slug = rest.join('/');
      if (lang === contentLocale) {
        slugMap.set(slug, post);
      }
    }
    // Second pass: fall back to zh for slugs not yet covered
    for (const post of posts) {
      const [lang, ...rest] = post.id.split('/');
      const slug = rest.join('/');
      if (lang === 'zh' && !slugMap.has(slug)) {
        slugMap.set(slug, post);
      }
    }
    for (const [slug, post] of slugMap) {
      paths.push({ params: { locale, slug }, props: { post } });
    }
  }
  return paths;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPostLayout title={post.data.title} date={post.data.date} tags={post.data.tags} toc={post.data.toc} headings={headings}>
  <Content />
</BlogPostLayout>
