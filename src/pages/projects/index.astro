---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    name: 'Dopamind',
    description: 'AI-powered ADHD Coach. Helping people with ADHD build better habits and stay focused.',
    url: 'https://dopamind.app',
  },
  {
    name: 'PhiloArt',
    description: 'My personal art gallery — photography, paintings, and digital art.',
    url: 'https://philoart.io',
  },
  {
    name: 'Bilingual Ebook Translator',
    description: 'Turn any EPUB into a bilingual edition — runs in your browser with your own LLM API key.',
    url: '/projects/ebook-translator',
    cta: 'Open tool →',
  },
];
---

<BaseLayout title="Projects — Philo Li" description="Projects by Philo Li.">
  <main class="projects-page">
    <h1 class="projects-page__title">Projects</h1>
    <div class="projects-page__grid">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .projects-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: calc(var(--nav-height) + var(--space-lg)) var(--space-md) var(--space-xl);
  }
  .projects-page__title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-text-muted);
    font-weight: 400;
    margin-bottom: var(--space-lg);
  }
  .projects-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }
</style>
