---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Default locale is 'en': prefer en/ post, fallback to zh/
  const slugMap = new Map();
  for (const post of posts) {
    const [lang, ...rest] = post.id.split('/');
    const slug = rest.join('/');
    if (lang === 'en' || !slugMap.has(slug)) {
      slugMap.set(slug, post);
    }
  }
  return [...slugMap.entries()].map(([slug, post]) => ({
    params: { slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogPostLayout title={post.data.title} date={post.data.date} tags={post.data.tags}>
  <Content />
</BlogPostLayout>
