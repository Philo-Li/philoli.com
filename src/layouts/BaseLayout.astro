---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';
import '@fontsource/inter/900.css';
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';
import type {
  OrganizationSchema,
  WebSiteSchema,
  PersonSchema,
  ArticleSchema,
  WebPageSchema,
  CollectionPageSchema,
} from '../components/StructuredData.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_LOCALE, LOCALES, RTL_LOCALES, isLocale } from '../i18n';
import '../styles/global.css';

type Schema =
  | OrganizationSchema
  | WebSiteSchema
  | PersonSchema
  | ArticleSchema
  | WebPageSchema
  | CollectionPageSchema;

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noAutoLocale?: boolean;
  structuredData?: Schema[];
  lcpImage?: string;
  lcpImageSrcSet?: string;
  lcpImageSizes?: string;
}

const {
  title,
  description,
  image,
  type,
  noAutoLocale,
  structuredData: externalSchema,
  lcpImage,
  lcpImageSrcSet,
  lcpImageSizes,
} = Astro.props;
const site = String(Astro.site).replace(/\/+$/, '');
const FALLBACK_WEBPAGE = { '@type': 'WebPage' as const, name: title, url: new URL(Astro.url.pathname, Astro.site).toString(), isPartOf: { '@type': 'WebSite' as const, name: 'Philo Li', url: site } };
const sd = externalSchema ?? [FALLBACK_WEBPAGE];
const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const dir = RTL_LOCALES.has(locale) ? 'rtl' : 'ltr';
const isDefaultLocale = locale === DEFAULT_LOCALE;
const autoLocaleEnabled = isDefaultLocale && !noAutoLocale;
const supportedLocalesJson = JSON.stringify(LOCALES);
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    {autoLocaleEnabled && (
      <script is:inline set:html={`(() => {
        try {
          var SUPPORTED = ${supportedLocalesJson};
          var DEFAULT = '${DEFAULT_LOCALE}';
          var STORAGE_KEY = 'preferred-locale';
          var saved = localStorage.getItem(STORAGE_KEY);
          var target = null;
          if (saved && SUPPORTED.indexOf(saved) !== -1) {
            if (saved !== DEFAULT) target = saved;
          } else {
            var raw = (navigator.language || DEFAULT).toLowerCase();
            var base = raw.split('-')[0];
            if (base !== DEFAULT && SUPPORTED.indexOf(base) !== -1) target = base;
            else if (SUPPORTED.indexOf(raw) !== -1 && raw !== DEFAULT) target = raw;
          }
          if (target) {
            var path = location.pathname;
            var firstSeg = path.split('/')[1] || '';
            if (SUPPORTED.indexOf(firstSeg) === -1) {
              var newPath = path === '/' ? '/' + target + '/' : '/' + target + path;
              location.replace(newPath + location.search + location.hash);
            }
          }
        } catch (e) {}
      })();`} />
    )}
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://api.goshipfast.com" />
    {lcpImage && (
      <link
        rel="preload"
        as="image"
        href={lcpImage}
        imagesrcset={lcpImageSrcSet}
        imagesizes={lcpImageSizes}
        fetchpriority="high"
      />
    )}
    <SEOHead title={title} description={description} image={image} type={type} />
    <StructuredData schemas={sd} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = 'theme';
        try {
          const savedTheme = localStorage.getItem(storageKey);
          const theme = savedTheme === 'light' || savedTheme === 'dark' ? savedTheme : 'dark';
          root.dataset.theme = theme;
        } catch {
          root.dataset.theme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <script is:inline>
      (() => {
        const loadAnalytics = () => {
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=G-V10E8BFFM0';
          document.head.appendChild(s);
          s.onload = function() {
            window.dataLayer = window.dataLayer || [];
            function gtag(){window.dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-V10E8BFFM0');
          };
          var t = document.createElement('script');
          t.async = true;
          t.src = 'https://api.goshipfast.com/tracker.js';
          t.setAttribute('data-project', 'cmp4s0v08006cf9ys27kd289j');
          t.setAttribute('data-endpoint', 'https://api.goshipfast.com');
          document.head.appendChild(t);
        };
        if (window.requestIdleCallback) {
          requestIdleCallback(loadAnalytics, { timeout: 3000 });
        } else {
          setTimeout(loadAnalytics, 3000);
        }
      })();
    </script>
  </body>
</html>

