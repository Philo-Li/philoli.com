---
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';
import type {
  OrganizationSchema,
  WebSiteSchema,
  PersonSchema,
  ArticleSchema,
  WebPageSchema,
  CollectionPageSchema,
} from '../components/StructuredData.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_LOCALE, LOCALES, RTL_LOCALES, isLocale } from '../i18n';
import '../styles/global.css';

type Schema =
  | OrganizationSchema
  | WebSiteSchema
  | PersonSchema
  | ArticleSchema
  | WebPageSchema
  | CollectionPageSchema;

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  noAutoLocale?: boolean;
  structuredData?: Schema[];
}

const { title, description, image, type, noAutoLocale, structuredData: externalSchema } = Astro.props;
const site = String(Astro.site).replace(/\/+$/, '');
const FALLBACK_WEBPAGE = { '@type': 'WebPage' as const, name: title, url: new URL(Astro.url.pathname, Astro.site).toString(), isPartOf: { '@type': 'WebSite' as const, name: 'Philo Li', url: site } };
const sd = externalSchema ?? [FALLBACK_WEBPAGE];
const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const dir = RTL_LOCALES.has(locale) ? 'rtl' : 'ltr';
const isDefaultLocale = locale === DEFAULT_LOCALE;
const autoLocaleEnabled = isDefaultLocale && !noAutoLocale;
const supportedLocalesJson = JSON.stringify(LOCALES);
---

<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    {autoLocaleEnabled && (
      <script is:inline set:html={`(() => {
        try {
          var SUPPORTED = ${supportedLocalesJson};
          var DEFAULT = '${DEFAULT_LOCALE}';
          var STORAGE_KEY = 'preferred-locale';
          var saved = localStorage.getItem(STORAGE_KEY);
          var target = null;
          if (saved && SUPPORTED.indexOf(saved) !== -1) {
            if (saved !== DEFAULT) target = saved;
          } else {
            var raw = (navigator.language || DEFAULT).toLowerCase();
            var base = raw.split('-')[0];
            if (base !== DEFAULT && SUPPORTED.indexOf(base) !== -1) target = base;
            else if (SUPPORTED.indexOf(raw) !== -1 && raw !== DEFAULT) target = raw;
          }
          if (target) {
            var path = location.pathname;
            var firstSeg = path.split('/')[1] || '';
            if (SUPPORTED.indexOf(firstSeg) === -1) {
              var newPath = path === '/' ? '/' + target + '/' : '/' + target + path;
              location.replace(newPath + location.search + location.hash);
            }
          }
        } catch (e) {}
      })();`} />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" /></noscript>
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://api.goshipfast.com" />
    <SEOHead title={title} description={description} image={image} type={type} />
    <StructuredData schemas={sd} />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const storageKey = 'theme';
        try {
          const savedTheme = localStorage.getItem(storageKey);
          const theme = savedTheme === 'light' || savedTheme === 'dark' ? savedTheme : 'dark';
          root.dataset.theme = theme;
        } catch {
          root.dataset.theme = 'dark';
        }
      })();
    </script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-V10E8BFFM0"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: unknown[]) { window.dataLayer.push(args); }
      gtag('js', new Date());
      gtag('config', 'G-V10E8BFFM0');
    </script>
    <!-- goshipfast analytics -->
    <script
      is:inline
      async
      src="https://api.goshipfast.com/tracker.js"
      data-project="cmp4s0v08006cf9ys27kd289j"
      data-endpoint="https://api.goshipfast.com"
    ></script>
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
