---
import BaseLayout from './BaseLayout.astro';
import SubscribeForm from '../components/forms/SubscribeForm.astro';
import { DEFAULT_LOCALE, formatDate, isLocale, localizedPath, useTranslations } from '../i18n';
import type { MarkdownHeading } from 'astro';

interface RelatedPost {
  slug: string;
  title: string;
  cover: string | null;
  date: Date;
}

interface Props {
  title: string;
  date: Date;
  description?: string;
  cover?: string;
  tags?: string | string[];
  toc?: boolean;
  headings?: MarkdownHeading[];
  prev?: RelatedPost | null;
  next?: RelatedPost | null;
  moreReading?: RelatedPost[];
}

const { title, date, description, cover, tags, toc, headings, prev, next, moreReading = [] } = Astro.props;
const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : DEFAULT_LOCALE;
const t = useTranslations(locale);
const formattedDate = formatDate(date, locale, { year: 'numeric', month: 'long', day: 'numeric' });
const tagList = Array.isArray(tags) ? tags : tags ? [tags] : [];
const tocItems = toc && headings ? headings.filter(h => h.depth >= 2 && h.depth <= 3) : [];
const showToc = tocItems.length > 0;

const BRAND_BY_LANG: Record<string, string> = {
  zh: 'Philo 说会儿',
  'zh-TW': 'Philo 說會兒',
};
const brand = BRAND_BY_LANG[locale] ?? "Philo's Reflections";
const year = new Date().getFullYear();
const CC_URL = 'https://creativecommons.org/licenses/by-nc-sa/4.0/';

const site = String(Astro.site).replace(/\/+$/, '');
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const articleSchema = [
  {
    '@type': 'Article' as const,
    headline: title,
    url: pageUrl,
    datePublished: date.toISOString(),
    author: { '@type': 'Person' as const, name: 'Philo Li', url: site },
    publisher: { '@type': 'Organization' as const, name: 'Philo Li', url: site },
    image: cover ? new URL(cover, Astro.site).toString() : undefined,
    description,
  },
];
---

<BaseLayout title={`${title} — Philo Li`} type="article" structuredData={articleSchema}>
  <article class="blog-post">
    <header class="blog-post__header">
      <h1 class="blog-post__title">{title}</h1>
      <div class="blog-post__meta">
        <time>{formattedDate}</time>
        {tagList.map(tag => <span class="blog-post__tag">#{tag}</span>)}
      </div>
    </header>
    <div class="blog-post__content">
      <slot />
    </div>

    <footer class="blog-post__footer">
      <section class="blog-post__cta" aria-label={t('newsletterCta.label')}>
        <div class="blog-post__cta-brand">
          <span class="blog-post__cta-brand-name">{brand}</span>
          <span class="blog-post__cta-divider" aria-hidden="true"></span>
          <span class="blog-post__cta-headline">{t('blogPost.ctaHeadline')}</span>
        </div>
        <SubscribeForm />
      </section>

      {moreReading.length > 0 && (
        <section class="blog-more" aria-label={t('blogPost.moreReading')}>
          <div class="blog-more__label">{t('blogPost.moreReading')}</div>
          <ul class="blog-more__list">
            {moreReading.map((p) => {
              const href = localizedPath(`/blog/${p.slug.toLowerCase()}`, locale);
              return (
                <li class="blog-more__item">
                  <a href={href} class="blog-more__link">
                    <div class:list={['blog-more__cover', { 'blog-more__cover--placeholder': !p.cover }]}>
                      {p.cover
                        ? <img src={p.cover} alt="" loading="lazy" />
                        : <span class="blog-more__cover-glyph" aria-hidden="true">{p.title.charAt(0)}</span>}
                    </div>
                    <h3 class="blog-more__title">{p.title}</h3>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )}

      {(prev || next) && (
        <nav class="blog-nav" aria-label="Article navigation">
          <div class="blog-nav__side blog-nav__side--prev">
            {prev && (
              <a href={localizedPath(`/blog/${prev.slug.toLowerCase()}`, locale)} class="blog-nav__link">
                <span class="blog-nav__label">← {t('blogPost.previous')}</span>
                <span class="blog-nav__title">{prev.title}</span>
              </a>
            )}
          </div>
          <div class="blog-nav__side blog-nav__side--next">
            {next && (
              <a href={localizedPath(`/blog/${next.slug.toLowerCase()}`, locale)} class="blog-nav__link">
                <span class="blog-nav__label">{t('blogPost.next')} →</span>
                <span class="blog-nav__title">{next.title}</span>
              </a>
            )}
          </div>
        </nav>
      )}

      <p class="blog-post__license">
        © {year} Philo Li · {t('blogPost.licensePrefix')} <a href={CC_URL} target="_blank" rel="noopener license">CC BY-NC-SA 4.0</a>
      </p>
    </footer>
  </article>
  {showToc && (
    <aside class="blog-toc" aria-label="Table of contents">
      <div class="blog-toc__title">目录</div>
      <nav>
        <ul>
          {tocItems.map(item => (
            <li class={`blog-toc__item blog-toc__item--depth-${item.depth}`}>
              <a href={`#${item.slug}`}>{item.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}
</BaseLayout>
{showToc && (
  <script>
    const links = document.querySelectorAll<HTMLAnchorElement>('.blog-toc a');
    const sections = Array.from(links)
      .map(a => document.getElementById(decodeURIComponent(a.getAttribute('href')!.slice(1))))
      .filter((el): el is HTMLElement => !!el);
    const linkBySlug = new Map<string, HTMLAnchorElement>();
    links.forEach(a => linkBySlug.set(decodeURIComponent(a.getAttribute('href')!.slice(1)), a));
    let active: HTMLAnchorElement | null = null;
    const setActive = (el: HTMLAnchorElement | null) => {
      if (active === el) return;
      active?.classList.remove('is-active');
      el?.classList.add('is-active');
      active = el;
    };
    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter(e => e.isIntersecting);
      if (visible.length === 0) return;
      visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      const top = visible[0].target as HTMLElement;
      const link = linkBySlug.get(top.id);
      if (link) setActive(link);
    }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });
    sections.forEach(s => observer.observe(s));
  </script>
)}

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
    padding: calc(var(--nav-height) + var(--space-lg)) var(--space-md) var(--space-xl);
  }
  .blog-post__header {
    margin-bottom: var(--space-lg);
  }
  .blog-post__title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-heading);
  }
  .blog-post__meta {
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-sm);
  }
  .blog-post__tag {
    color: var(--color-accent);
  }
  .blog-post__content {
    font-size: 1.05rem;
    line-height: 1.8;
  }
  .blog-post__content :global(h2) {
    font-size: 1.5rem;
    margin: var(--space-lg) 0 var(--space-sm);
    color: var(--color-heading);
  }
  .blog-post__content :global(h3) {
    font-size: 1.2rem;
    margin: var(--space-md) 0 var(--space-xs);
    color: var(--color-heading);
  }
  .blog-post__content :global(p) {
    margin-bottom: var(--space-sm);
  }
  .blog-post__content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-post__content :global(code) {
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 0;
    font-size: 0.9em;
    font-family: var(--font-mono);
    overflow-wrap: anywhere;
  }
  .blog-post__content :global(pre) {
    background: var(--color-surface);
    padding: var(--space-sm);
    border-radius: 0;
    overflow-x: auto;
    margin-bottom: var(--space-sm);
  }
  .blog-post__content :global(pre code) {
    background: none;
    padding: 0;
  }
  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-sm);
    color: var(--color-text-subtle);
    margin: var(--space-sm) 0;
  }
  .blog-post__content :global(img) {
    border-radius: 0;
    margin: var(--space-md) 0;
  }
  .blog-post__content :global(.post-cover) {
    margin: var(--space-md) 0 var(--space-lg);
  }
  .blog-post__content :global(.post-cover img) {
    width: 100%;
    margin: 0;
  }
  .blog-post__content :global(.book-cover) {
    display: flex;
    justify-content: center;
    margin: var(--space-md) 0 var(--space-sm);
  }
  .blog-post__content :global(.book-cover img) {
    width: 300px;
    margin: 0;
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.16);
  }
  .blog-post__content :global(.book-fit) {
    margin: 0 0 var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
  }
  .blog-post__content :global(.book-fit p) {
    margin: 0 0 0.65rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .blog-post__content :global(.book-fit ol) {
    margin: 0;
    padding-left: 1.35rem;
  }
  .blog-post__content :global(.book-fit li) {
    margin: 0.35rem 0;
  }
  .blog-post__content :global(.book-figure) {
    margin: var(--space-sm) 0 var(--space-md);
  }
  .blog-post__content :global(.book-figure img) {
    width: 100%;
    border-radius: 12px;
    margin: 0;
  }
  .blog-post__content :global(.formula-pair) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    margin: var(--space-md) 0;
  }
  .blog-post__content :global(.formula-card) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-sm) var(--space-md);
  }
  .blog-post__content :global(.formula-card__label) {
    margin: 0 0 0.35rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .blog-post__content :global(.formula-card__moves) {
    margin: 0 0 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }
  .blog-post__content :global(.formula-card ul) {
    margin: 0;
    padding-left: 1.25rem;
  }
  .blog-post__content :global(.formula-card li) {
    margin: 0.25rem 0;
    font-size: 0.95rem;
  }
  @media (max-width: 600px) {
    .blog-post__content :global(.formula-pair) {
      grid-template-columns: 1fr;
    }
  }
  .blog-post__footer {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }
  .blog-post__cta {
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .blog-post__cta-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-bottom: var(--space-sm);
    text-align: center;
  }
  .blog-post__cta-brand-name {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 1px;
    color: var(--color-heading);
  }
  .blog-post__cta-divider {
    width: 18px;
    height: 2px;
    background: var(--color-accent);
    display: inline-block;
  }
  .blog-post__cta-headline {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .blog-post__cta :global(.subscribe-form) {
    max-width: 28rem;
    margin: 0 auto;
  }

  /* ---- More reading ---- */
  .blog-more {
    margin-top: var(--space-md);
  }
  .blog-more__label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }
  .blog-more__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
  }
  .blog-more__item {
    margin: 0;
  }
  .blog-more__link {
    display: block;
    color: var(--color-text);
    transition: opacity 0.2s ease;
  }
  .blog-more__link:hover {
    opacity: 0.75;
  }
  .blog-more__cover {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.6rem;
  }
  .blog-more__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .blog-more__cover--placeholder {
    background: color-mix(in srgb, var(--color-accent) 14%, var(--color-bg));
    color: var(--color-accent);
  }
  .blog-more__cover-glyph {
    font-size: 1.8rem;
    font-weight: 600;
    line-height: 1;
    opacity: 0.85;
  }
  .blog-more__title {
    font-size: 0.9rem;
    line-height: 1.4;
    font-weight: 500;
    color: var(--color-heading);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---- Prev / Next nav ---- */
  .blog-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }
  .blog-nav__side {
    min-width: 0;
  }
  .blog-nav__side--next {
    text-align: right;
  }
  .blog-nav__link {
    display: inline-block;
    color: var(--color-text-subtle);
    transition: color 0.2s ease;
  }
  .blog-nav__link:hover {
    color: var(--color-heading);
  }
  .blog-nav__label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-muted);
    margin-bottom: 4px;
  }
  .blog-nav__title {
    display: block;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-heading);
  }

  .blog-post__license {
    margin: var(--space-md) 0 0;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-align: center;
    letter-spacing: 0.3px;
  }
  .blog-post__license a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-post__license a:hover {
    color: var(--color-heading);
  }

  @media (max-width: 600px) {
    .blog-more__list {
      grid-template-columns: 1fr;
    }
  }

  .blog-toc {
    position: fixed;
    top: calc(var(--nav-height) + var(--space-lg));
    right: max(var(--space-md), calc(50% - 720px / 2 - 240px));
    width: 200px;
    max-height: calc(100vh - var(--nav-height) - var(--space-lg) * 2);
    overflow-y: auto;
    font-size: 0.85rem;
    line-height: 1.5;
    padding-left: var(--space-sm);
    border-left: 1px solid var(--color-border);
  }
  .blog-toc__title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }
  .blog-toc nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .blog-toc__item {
    margin: 0.35rem 0;
  }
  .blog-toc__item--depth-3 {
    padding-left: 0.9rem;
    font-size: 0.8rem;
  }
  .blog-toc a {
    color: var(--color-text-subtle);
    text-decoration: none;
    display: block;
    transition: color 0.15s;
  }
  .blog-toc a:hover {
    color: var(--color-accent);
  }
  .blog-toc a.is-active {
    color: var(--color-accent);
    font-weight: 600;
  }
  @media (max-width: 1180px) {
    .blog-toc {
      display: none;
    }
  }
</style>
