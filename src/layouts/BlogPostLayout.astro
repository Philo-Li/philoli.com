---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
  tags?: string | string[];
}

const { title, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const tagList = Array.isArray(tags) ? tags : tags ? [tags] : [];
---

<BaseLayout title={`${title} — Philo Li`} type="article">
  <article class="blog-post">
    <header class="blog-post__header">
      <h1 class="blog-post__title">{title}</h1>
      <div class="blog-post__meta">
        <time>{formattedDate}</time>
        {tagList.map(tag => <span class="blog-post__tag">#{tag}</span>)}
      </div>
    </header>
    <div class="blog-post__content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    max-width: 720px;
    margin: 0 auto;
    padding: calc(var(--nav-height) + var(--space-lg)) var(--space-md) var(--space-xl);
  }
  .blog-post__header {
    margin-bottom: var(--space-lg);
  }
  .blog-post__title {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.3;
    color: var(--color-white);
  }
  .blog-post__meta {
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
    display: flex;
    gap: var(--space-sm);
  }
  .blog-post__tag {
    color: var(--color-accent);
  }
  .blog-post__content {
    font-size: 1.05rem;
    line-height: 1.8;
  }
  .blog-post__content :global(h2) {
    font-size: 1.5rem;
    margin: var(--space-lg) 0 var(--space-sm);
    color: var(--color-white);
  }
  .blog-post__content :global(h3) {
    font-size: 1.2rem;
    margin: var(--space-md) 0 var(--space-xs);
    color: var(--color-white);
  }
  .blog-post__content :global(p) {
    margin-bottom: var(--space-sm);
  }
  .blog-post__content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-post__content :global(code) {
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: var(--font-mono);
  }
  .blog-post__content :global(pre) {
    background: var(--color-surface);
    padding: var(--space-sm);
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: var(--space-sm);
  }
  .blog-post__content :global(pre code) {
    background: none;
    padding: 0;
  }
  .blog-post__content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-sm);
    color: var(--color-text-subtle);
    margin: var(--space-sm) 0;
  }
  .blog-post__content :global(img) {
    border-radius: 8px;
    margin: var(--space-md) 0;
  }
</style>
