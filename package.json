{
  "name": "philoli.com",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/copy-pdfjs-assets.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/copy-pdfjs-assets.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:translate": "node scripts/i18n/translate-i18n.mjs",
    "proxy:dev": "npx wrangler dev -c services/custom-llm-proxy/wrangler.jsonc",
    "proxy:deploy": "npx wrangler deploy -c services/custom-llm-proxy/wrangler.jsonc",
    "subscribe:dev": "npx wrangler dev -c services/subscribe-api/wrangler.toml",
    "subscribe:deploy": "npx wrangler deploy -c services/subscribe-api/wrangler.toml",
    "subscribe:sync-i18n": "node services/subscribe-api/scripts/sync-email-i18n.mjs",
    "subscribe:test": "npm --prefix services/subscribe-api run test"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.1",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "astro": "^6.0.5",
    "gif.js": "^0.2.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sanitize-html": "^2.17.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/jszip": "^3.4.0",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.184.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
